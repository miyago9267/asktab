{
  "manifest_version": 3,
  "name": "AskTab",
  "version": "0.2.0",
  "description": "Chat with any browser tab via local AI CLIs (claude, codex, gemini, opencode)",
  "permissions": ["tabs", "scripting", "storage", "nativeMessaging"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8787/*"],
  "action": {
    "default_title": "AskTab"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
